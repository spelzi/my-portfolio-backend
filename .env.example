# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# Never commit your actual .env file — it's already covered by .gitignore.
# In production (Railway, etc.), set these via the platform's Variables
# dashboard instead of uploading a .env file.

# ─── Email (contact form) ───────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
EMAIL_USER=youremail@gmail.com

# ─── Admin auth ──────────────────────────────────────────────────────────────
ADMIN_PASSWORD=your_secure_admin_password
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_long_random_secret_string

# ─── Supabase (posts / projects / videos storage) ───────────────────────────
# Project Settings → API in your Supabase dashboard.
# IMPORTANT: use the service_role key, NOT the anon/public key. The
# service_role key bypasses Row Level Security and must never be sent to
# the frontend — it belongs only in this backend's environment.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
